		"drizzle-kit": "^0.31.10",
		"postcss": "^8.5.8",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@libsql/client": "^0.17.2",
		"drizzle-orm": "^0.45.2",
